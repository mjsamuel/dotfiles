#!/bin/sh
WORKSPACES_FILE="$HOME/.config/workspaces"
if [ ! -f "$WORKSPACES_FILE" ]; then
	cat <<-EOF >"$WORKSPACES_FILE"
        ${HOME}/[Dd]eveloper
        ${HOME}/[Ww]ork
	EOF
fi

selected="$(
	FZF_DEFAULT_COMMAND="find $(xargs <"$WORKSPACES_FILE") -mindepth 1 -maxdepth 1 -type d -not -path '*/.*'" \
		fzf --preview 'eza {} --tree --level=1 --icons --color=always' \
		--prompt "session: " \
		--preview-window=right:50% --height=100% \
		--delimiter / --with-nth -2,-1 \
		--bind "enter:accept-non-empty" \
		--exit-0
)" || exit 0
selected_name=$(basename "$selected" | tr '.' '-')

if ! tmux has-session -t "$selected_name" 2>/dev/null; then
	tmux new-session -ds "$selected_name" -c "$selected"
fi

if [ -n "$TMUX" ]; then
	tmux switch-client -t "$selected_name"
else
	tmux attach -t "$selected_name"
fi

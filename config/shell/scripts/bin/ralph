#!/bin/bash
set -e

iterations="${1:-}"
if [ -z "$iterations" ]; then
	echo "Usage: $0 <iterations>"
	exit 1
fi

# jq filter to extract streaming text from assistant messages
stream_text='select(.type == "assistant").message.content[]? | select(.type == "text").text // empty | gsub("\n"; "\r\n") | . + "\r\n\n"'

# jq filter to extract final result
final_result='select(.type == "result").result // empty'

run_agent() {
	prompt_file="$1"

	for ((i = 1; i <= "$iterations"; i++)); do
		tmpfile=$(mktemp)
		trap "rm -f $tmpfile" EXIT

		cat "$prompt_file" |
			claude --verbose --print --output-format stream-json |
			grep --line-buffered '^{' |
			tee "$tmpfile" |
			jq --unbuffered -rj "$stream_text"

		result=$(jq -r "$final_result" "$tmpfile")

		if [[ "$result" == *"<promise>COMPLETE</promise>"* ]]; then
			echo "Ralph complete after $i iterations."
			return
		fi
	done
}

for ((i = 1; i <= "$iterations"; i++)); do
	run_agent ".mjsamuel/agents/plan-prompt.md" 1 # planner
	run_agent ".mjsamuel/agents/implement-prompt.md" 100 # implementor
	run_agent ".mjsamuel/agents/plan-prompt.md" 100 # implementor
done
